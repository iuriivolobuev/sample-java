<?xml version="1.0" encoding="UTF-8"?>
<!--suppress SpringXmlAutowireExplicitlyInspection -->
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd"
       default-autowire="constructor">

  <bean id="dataSource" class="org.postgresql.ds.PGSimpleDataSource">
    <property name="url" value="jdbc:postgresql://localhost:5432/dev"/>
    <property name="user" value="devuser"/>
    <property name="password" value="devpass"/>
  </bean>

  <bean class="org.flywaydb.core.api.configuration.ClassicConfiguration">
    <property name="dataSource" ref="dataSource"/>
    <property name="locations" value="db/migrations"/>
    <property name="table" value="schema_version"/>
  </bean>
  <bean id="flyway" class="org.flywaydb.core.Flyway" init-method="migrate"/>

  <bean class="sample.webapp.dao.JdbcConnectionHolder" depends-on="flyway"/>
  <bean id="dogDao" class="sample.webapp.dao.JdbcDogDao"/>
</beans>
