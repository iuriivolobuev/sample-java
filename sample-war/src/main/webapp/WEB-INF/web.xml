<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">
  <servlet>
    <servlet-name>dispatcher</servlet-name>
    <servlet-class>org.springframework.web.servlet.DispatcherServlet</servlet-class>
    <init-param>
      <param-name>contextConfigLocation</param-name>
      <param-value>classpath:/web-context.xml</param-value>
    </init-param>
  </servlet>
  <servlet>
    <servlet-name>sample</servlet-name>
    <servlet-class>sample.war.controller.SampleServlet</servlet-class>
  </servlet>
  <filter>
    <filter-name>sampleFilterA</filter-name>
    <filter-class>sample.war.controller.SampleFilterA</filter-class>
  </filter>
  <filter>
    <filter-name>sampleFilterB</filter-name>
    <filter-class>sample.war.controller.SampleFilterB</filter-class>
  </filter>

  <servlet-mapping>
    <servlet-name>dispatcher</servlet-name>
    <url-pattern>/</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>sample</servlet-name>
    <url-pattern>/sample</url-pattern>
  </servlet-mapping>
  <filter-mapping>
    <filter-name>sampleFilterA</filter-name>
    <servlet-name>sample</servlet-name>
  </filter-mapping>
  <filter-mapping>
    <filter-name>sampleFilterB</filter-name>
    <servlet-name>sample</servlet-name>
  </filter-mapping>
  
  <listener>
    <listener-class>sample.war.controller.SampleServletContextListener</listener-class>
  </listener>
</web-app>
